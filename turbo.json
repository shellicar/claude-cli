{
  "$schema": "node_modules/turbo/schema.json",
  "ui": "stream",
  "daemon": false,
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["tsconfig.json", "src/**/*.ts", "build.ts", "tsup.config.ts"],
      "outputs": ["dist"],
      "outputLogs": "new-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["tsconfig.check.json"],
      "outputs": ["**/node_modules/.cache/tsbuildinfo.json"],
      "outputLogs": "errors-only"
    },
    "watch": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
