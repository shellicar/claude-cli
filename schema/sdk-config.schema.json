{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "JSON Schema reference for editor autocomplete",
      "type": "string"
    },
    "model": {
      "default": "claude-sonnet-4-6",
      "description": "Claude model to use",
      "type": "string"
    },
    "historyReplay": {
      "default": {
        "enabled": true,
        "showThinking": false
      },
      "description": "History replay configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Replay history messages into the display on startup",
          "type": "boolean"
        },
        "showThinking": {
          "default": false,
          "description": "Show thinking blocks when replaying history",
          "type": "boolean"
        }
      }
    },
    "claudeMd": {
      "default": {
        "enabled": true
      },
      "description": "CLAUDE.md loading configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Load CLAUDE.md files as system prompts",
          "type": "boolean"
        }
      }
    },
    "compact": {
      "default": {
        "enabled": true,
        "inputTokens": 160000,
        "pauseAfterCompaction": true,
        "customInstructions": null
      },
      "description": "Compaction configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable conversation compaction",
          "type": "boolean"
        },
        "inputTokens": {
          "default": 160000,
          "description": "Token threshold at which compaction triggers",
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "pauseAfterCompaction": {
          "default": true,
          "description": "Whether to pause after a compaction occurs",
          "type": "boolean"
        },
        "customInstructions": {
          "default": null,
          "description": "Custom instructions to guide the compaction summary",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "advancedTools": {
      "default": {
        "enabled": false,
        "searchTool": null,
        "allowProgramaticExecution": [],
        "codeExecutionTool": "code_execution_20260120"
      },
      "description": "Advanced tool use configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Enable advanced tool use",
          "type": "boolean"
        },
        "searchTool": {
          "default": null,
          "description": "Search tool to prepend for deferred tool loading; omit when only using allowProgramaticExecution or input_examples",
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "regex",
                "bm25"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "allowProgramaticExecution": {
          "default": [],
          "description": "Tool names that can be called programmatically by code execution tools",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "codeExecutionTool": {
          "default": "code_execution_20260120",
          "description": "Code execution tool version allowed to call tools in allowProgramaticExecution",
          "type": "string",
          "enum": [
            "code_execution_20250825",
            "code_execution_20260120"
          ]
        }
      }
    }
  },
  "title": "Claude SDK CLI Configuration",
  "description": "Configuration for @shellicar/claude-sdk-cli"
}
