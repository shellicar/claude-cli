{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "JSON Schema reference for editor autocomplete",
      "type": "string"
    },
    "model": {
      "default": "claude-opus-4-8",
      "description": "Claude model to use",
      "type": "string"
    },
    "maxTokens": {
      "default": 32000,
      "description": "Maximum tokens per response",
      "type": "integer",
      "exclusiveMinimum": 0
    },
    "thinking": {
      "default": {
        "enabled": true,
        "effort": "high"
      },
      "description": "Extended thinking configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable extended thinking",
          "type": "boolean"
        },
        "effort": {
          "default": "high",
          "description": "Token effort level applied to all spending (thinking, text, tool calls)",
          "type": "string",
          "enum": [
            "max",
            "xhigh",
            "high",
            "medium",
            "low"
          ]
        }
      }
    },
    "historyReplay": {
      "default": {
        "enabled": true,
        "showThinking": false
      },
      "description": "History replay configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Replay history messages into the display on startup",
          "type": "boolean"
        },
        "showThinking": {
          "default": false,
          "description": "Show thinking blocks when replaying history",
          "type": "boolean"
        }
      }
    },
    "claudeMd": {
      "default": {
        "enabled": true,
        "sources": {
          "user": true,
          "project": true,
          "projectClaude": true,
          "local": true
        }
      },
      "description": "CLAUDE.md loading configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Load CLAUDE.md files as system prompts",
          "type": "boolean"
        },
        "sources": {
          "default": {
            "user": true,
            "project": true,
            "projectClaude": true,
            "local": true
          },
          "description": "Per-source CLAUDE.md loading control",
          "type": "object",
          "properties": {
            "user": {
              "default": true,
              "description": "Load ~/.claude/CLAUDE.md",
              "type": "boolean"
            },
            "project": {
              "default": true,
              "description": "Load ./CLAUDE.md",
              "type": "boolean"
            },
            "projectClaude": {
              "default": true,
              "description": "Load ./.claude/CLAUDE.md",
              "type": "boolean"
            },
            "local": {
              "default": true,
              "description": "Load ./CLAUDE.local.md",
              "type": "boolean"
            }
          }
        }
      }
    },
    "systemPrompt": {
      "default": {
        "enabled": true,
        "sources": {
          "user": true,
          "project": true,
          "projectClaude": true,
          "local": true
        },
        "text": null
      },
      "description": "System prompt (SYSTEM.md + inline) configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Load SYSTEM.md files as the system prompt",
          "type": "boolean"
        },
        "sources": {
          "default": {
            "user": true,
            "project": true,
            "projectClaude": true,
            "local": true
          },
          "description": "Per-source SYSTEM.md loading control",
          "type": "object",
          "properties": {
            "user": {
              "default": true,
              "description": "Load ~/.claude/SYSTEM.md",
              "type": "boolean"
            },
            "project": {
              "default": true,
              "description": "Load ./SYSTEM.md",
              "type": "boolean"
            },
            "projectClaude": {
              "default": true,
              "description": "Load ./.claude/SYSTEM.md",
              "type": "boolean"
            },
            "local": {
              "default": true,
              "description": "Load ./SYSTEM.local.md",
              "type": "boolean"
            }
          }
        },
        "text": {
          "default": null,
          "description": "Inline system prompt contributed by config, appended after SYSTEM.md files",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "compact": {
      "default": {
        "enabled": false,
        "inputTokens": 160000,
        "pauseAfterCompaction": true,
        "customInstructions": null
      },
      "description": "Compaction configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Enable conversation compaction",
          "type": "boolean"
        },
        "inputTokens": {
          "default": 160000,
          "description": "Token threshold at which compaction triggers",
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "pauseAfterCompaction": {
          "default": true,
          "description": "Whether to pause after a compaction occurs",
          "type": "boolean"
        },
        "customInstructions": {
          "default": null,
          "description": "Custom instructions to guide the compaction summary",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "advancedTools": {
      "default": {
        "enabled": true,
        "searchTool": null,
        "allowProgrammaticExecution": [],
        "codeExecutionTool": "code_execution_20260120"
      },
      "description": "Advanced tool use configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Enable advanced tool use",
          "type": "boolean"
        },
        "searchTool": {
          "default": null,
          "description": "Search tool to prepend for deferred tool loading; omit when only using allowProgrammaticExecution or input_examples",
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "regex",
                "bm25"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "allowProgrammaticExecution": {
          "default": [],
          "description": "Tool names that can be called programmatically by code execution tools",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "codeExecutionTool": {
          "default": "code_execution_20260120",
          "description": "Code execution tool version allowed to call tools in allowProgrammaticExecution",
          "type": "string",
          "enum": [
            "code_execution_20250825",
            "code_execution_20260120"
          ]
        }
      }
    },
    "serverTools": {
      "default": {
        "webSearch": {
          "enabled": true,
          "version": "web_search_20260209",
          "allowedCallers": [
            "direct"
          ]
        },
        "webFetch": {
          "enabled": true,
          "version": "web_fetch_20260209",
          "allowedCallers": [
            "direct"
          ]
        }
      },
      "description": "Server-side tool configuration",
      "type": "object",
      "properties": {
        "webSearch": {
          "default": {
            "enabled": true,
            "version": "web_search_20260209",
            "allowedCallers": [
              "direct"
            ]
          },
          "description": "Web search configuration",
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "description": "Enable web search",
              "type": "boolean"
            },
            "version": {
              "default": "web_search_20260209",
              "description": "API version. 20260209 adds dynamic filtering (not ZDR without allowedCallers: [\"direct\"])",
              "type": "string",
              "enum": [
                "web_search_20250305",
                "web_search_20260209"
              ]
            },
            "allowedCallers": {
              "default": [
                "direct"
              ],
              "description": "Who can invoke this tool. Set to [\"direct\"] for ZDR eligibility",
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "direct",
                  "code_execution"
                ]
              }
            }
          }
        },
        "webFetch": {
          "default": {
            "enabled": true,
            "version": "web_fetch_20260209",
            "allowedCallers": [
              "direct"
            ]
          },
          "description": "Web fetch configuration",
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "description": "Enable web fetch",
              "type": "boolean"
            },
            "version": {
              "default": "web_fetch_20260209",
              "description": "API version. 20260209 adds dynamic filtering (not ZDR without allowedCallers: [\"direct\"])",
              "type": "string",
              "enum": [
                "web_fetch_20250910",
                "web_fetch_20260209"
              ]
            },
            "allowedCallers": {
              "default": [
                "direct"
              ],
              "description": "Who can invoke this tool. Set to [\"direct\"] for ZDR eligibility",
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "direct",
                  "code_execution"
                ]
              }
            }
          }
        }
      }
    },
    "hooks": {
      "default": {
        "approvalNotify": null
      },
      "description": "Hook configuration",
      "type": "object",
      "properties": {
        "approvalNotify": {
          "default": null,
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "command": {
                  "type": "string",
                  "description": "Command to run when approval is pending"
                },
                "delayMs": {
                  "default": 0,
                  "description": "Milliseconds to wait before running the command. 0 means immediate",
                  "type": "integer",
                  "minimum": 0
                }
              },
              "required": [
                "command"
              ]
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "tools": {
      "default": {
        "exec": false,
        "execV2": false,
        "execV3": true
      },
      "description": "Execution tool selection",
      "type": "object",
      "properties": {
        "exec": {
          "default": false,
          "description": "Enable the original Exec tool (steps + chaining schema)",
          "type": "boolean"
        },
        "execV2": {
          "default": false,
          "description": "Enable the ExecV2 tool (recursive AST schema)",
          "type": "boolean"
        },
        "execV3": {
          "default": true,
          "description": "Enable the ExecV3 tool (flat commands + forward op)",
          "type": "boolean"
        }
      }
    },
    "statusBar": {
      "default": {
        "showConversationId": true
      },
      "description": "Status bar configuration",
      "type": "object",
      "properties": {
        "showConversationId": {
          "default": true,
          "description": "Show the conversation id on the status bar (top line)",
          "type": "boolean"
        }
      }
    },
    "permissions": {
      "default": {
        "default": {
          "read": "approve",
          "write": "approve",
          "delete": "ask"
        },
        "outside": {
          "read": "approve",
          "write": "ask",
          "delete": "deny"
        }
      },
      "description": "Tool approval permission matrix",
      "type": "object",
      "properties": {
        "default": {
          "default": {
            "read": "approve",
            "write": "approve",
            "delete": "ask"
          },
          "description": "Permissions for paths inside the working directory",
          "type": "object",
          "properties": {
            "read": {
              "default": "approve",
              "description": "Action for read operations",
              "type": "string",
              "enum": [
                "approve",
                "ask",
                "deny"
              ]
            },
            "write": {
              "default": "approve",
              "description": "Action for write operations",
              "type": "string",
              "enum": [
                "approve",
                "ask",
                "deny"
              ]
            },
            "delete": {
              "default": "ask",
              "description": "Action for delete operations",
              "type": "string",
              "enum": [
                "approve",
                "ask",
                "deny"
              ]
            }
          }
        },
        "outside": {
          "default": {
            "read": "approve",
            "write": "ask",
            "delete": "deny"
          },
          "description": "Permissions for paths outside the working directory",
          "type": "object",
          "properties": {
            "read": {
              "default": "approve",
              "description": "Action for read operations",
              "type": "string",
              "enum": [
                "approve",
                "ask",
                "deny"
              ]
            },
            "write": {
              "default": "ask",
              "description": "Action for write operations",
              "type": "string",
              "enum": [
                "approve",
                "ask",
                "deny"
              ]
            },
            "delete": {
              "default": "deny",
              "description": "Action for delete operations",
              "type": "string",
              "enum": [
                "approve",
                "ask",
                "deny"
              ]
            }
          }
        }
      }
    },
    "preventSleep": {
      "default": {
        "enabled": true,
        "platforms": {
          "macos": "caffeinate",
          "windows": null,
          "linux": null
        }
      },
      "description": "Sleep prevention during in-flight network requests",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Hold the machine awake during in-flight network requests (opt-out)",
          "type": "boolean"
        },
        "platforms": {
          "default": {
            "macos": "caffeinate",
            "windows": null,
            "linux": null
          },
          "description": "Per-platform wake-lock command. Only macOS is wired; windows/linux are null placeholders",
          "type": "object",
          "properties": {
            "macos": {
              "default": "caffeinate",
              "description": "macOS wake-lock command, spawned with -i to inhibit idle sleep. null disables on macOS",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "windows": {
              "default": null,
              "description": "Windows wake-lock command. Not yet wired; null disables",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "linux": {
              "default": null,
              "description": "Linux wake-lock command. Not yet wired; null disables",
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            }
          }
        }
      }
    },
    "persistence": {
      "default": {
        "database": "persistence.db"
      },
      "description": "Persistence (SQLite) configuration",
      "type": "object",
      "properties": {
        "database": {
          "default": "persistence.db",
          "description": "SQLite database filename, stored under ~/.claude, for Ref/PreviewEdit persistence across restarts",
          "type": "string"
        }
      }
    },
    "markdown": {
      "default": {
        "enabled": true,
        "streaming": true
      },
      "description": "Markdown rendering configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Render assistant responses as styled markdown",
          "type": "boolean"
        },
        "streaming": {
          "default": true,
          "description": "Render markdown live while the response streams (ignored when enabled is off)",
          "type": "boolean"
        }
      }
    },
    "memory": {
      "default": {
        "tenantId": null,
        "environment": {},
        "git": {
          "enabled": true
        }
      },
      "description": "Persistent memory configuration",
      "type": "object",
      "properties": {
        "tenantId": {
          "default": null,
          "description": "Optional separation lever: selects a distinct memory.<tenantId>.db file for physical isolation. Not a search filter.",
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "environment": {
          "default": {},
          "description": "Static key:value pairs stamped onto every memory written from this machine.",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "git": {
          "default": {
            "enabled": true
          },
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "description": "Derive org/repo/project keys from the git remote.",
              "type": "boolean"
            }
          }
        }
      }
    },
    "tap": {
      "default": {
        "enabled": false,
        "url": "nats://localhost:4222",
        "label": {}
      },
      "description": "NATS event tap (stage 1 observability) configuration",
      "type": "object",
      "properties": {
        "enabled": {
          "default": false,
          "description": "Publish conversation activity as NATS tap events. Disabled (default) has zero effect",
          "type": "boolean"
        },
        "url": {
          "default": "nats://localhost:4222",
          "description": "NATS broker URL. Enabling is never done by editing this",
          "type": "string"
        },
        "label": {
          "default": {},
          "description": "Creator-supplied metadata stamped on run_started (org, mission, role, kind, location)",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      }
    }
  },
  "title": "Claude SDK CLI Configuration",
  "description": "Configuration for @shellicar/claude-sdk-cli"
}
