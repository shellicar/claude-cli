{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["ES2024", "ESNext.AsyncIterable"],
    "rootDir": ".",
    "moduleResolution": "bundler",
    "module": "es2022",
    "target": "es2024",
    "strictNullChecks": true
  },
  "include": ["**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
