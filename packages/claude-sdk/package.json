{
  "name": "@shellicar/claude-sdk",
  "version": "1.0.0-beta.22",
  "private": false,
  "license": "MIT",
  "author": "Stephen Hellicar",
  "contributors": [
    "BananaBot9000 <bananabot9000@bananabot.dev>",
    "Claude (Anthropic) <noreply@anthropic.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shellicar/claude-cli.git"
  },
  "bugs": {
    "url": "https://github.com/shellicar/claude-cli/issues"
  },
  "homepage": "https://github.com/shellicar/claude-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./defineTool": {
      "import": {
        "types": "./dist/esm/public/defineTool.d.ts",
        "default": "./dist/esm/defineTool.js"
      },
      "require": {
        "types": "./dist/cjs/public/defineTool.d.cts",
        "default": "./dist/cjs/defineTool.cjs"
      }
    },
    "./ToolCancelledError": {
      "import": {
        "types": "./dist/esm/public/ToolCancelledError.d.ts",
        "default": "./dist/esm/ToolCancelledError.js"
      },
      "require": {
        "types": "./dist/cjs/public/ToolCancelledError.d.cts",
        "default": "./dist/cjs/ToolCancelledError.cjs"
      }
    },
    "./ToolRefusedError": {
      "import": {
        "types": "./dist/esm/public/ToolRefusedError.d.ts",
        "default": "./dist/esm/ToolRefusedError.js"
      },
      "require": {
        "types": "./dist/cjs/public/ToolRefusedError.d.cts",
        "default": "./dist/cjs/ToolRefusedError.cjs"
      }
    },
    "./pathSchema": {
      "import": {
        "types": "./dist/esm/public/pathSchema.d.ts",
        "default": "./dist/esm/pathSchema.js"
      },
      "require": {
        "types": "./dist/cjs/public/pathSchema.d.cts",
        "default": "./dist/cjs/pathSchema.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "watch": "tsup --watch",
    "start": "node dist/main.js",
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.check.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@js-joda/core": "^5.7.0",
    "@js-joda/locale_en": "^4.15.3",
    "@js-joda/timezone": "^2.25.2",
    "@shellicar/claude-core": "workspace:^",
    "@shellicar/core-di-lite": "^1.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@shellicar/build-clean": "^1.3.6",
    "@shellicar/build-version": "^2.0.0",
    "@shellicar/typescript-config": "workspace:^",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.5",
    "esbuild": "^0.28.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
