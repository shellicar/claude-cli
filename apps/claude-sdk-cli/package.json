    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@js-joda/core": "^5.7.0",
    "@shellicar/claude-core": "workspace:^",
    "@shellicar/claude-sdk": "workspace:^",
    "@shellicar/claude-sdk-tools": "workspace:^",
    "@shellicar/core-di-lite": "^1.0.2",
