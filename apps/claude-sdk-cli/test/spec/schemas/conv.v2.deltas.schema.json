{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "delta"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "text"
      ],
      "additionalProperties": {}
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "block"
        },
        "blockType": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "thinking",
                "text",
                "tool_use"
              ]
            },
            {
              "type": "string"
            }
          ]
        }
      },
      "required": [
        "type",
        "blockType"
      ],
      "additionalProperties": {}
    }
  ]
}
