{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shellicar.dev/tap.v1.schema.json",
  "title": "tap.v1 event",
  "description": "A single event on tap.v1.{conversationId}.events. Add-only within v1: additionalProperties stays open so unknown fields are ignored, and `type` is a plain string (not an enum) so unknown event types validate rather than being rejected — the harness skips them.",
  "type": "object",
  "required": ["type", "run", "ts"],
  "additionalProperties": true,
  "properties": {
    "type": { "type": "string" },
    "run": { "type": "string" },
    "ts": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "required": ["type"], "properties": { "type": { "const": "run_started" } } },
      "then": {
        "required": ["conv", "pid", "label"],
        "properties": {
          "conv": { "type": "string" },
          "pid": { "type": "number" },
          "label": { "type": "object" }
        }
      }
    },
    {
      "if": { "required": ["type"], "properties": { "type": { "const": "run_ended" } } },
      "then": {
        "required": ["reason"],
        "properties": { "reason": { "type": "string" } }
      }
    },
    {
      "if": { "required": ["type"], "properties": { "type": { "const": "turn_ended" } } },
      "then": {
        "required": ["stopReason"],
        "properties": { "stopReason": { "type": "string" } }
      }
    },
    {
      "if": { "required": ["type"], "properties": { "type": { "const": "tool_use" } } },
      "then": {
        "required": ["id", "name", "input"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "input": { "type": "object" }
        }
      }
    },
    {
      "if": { "required": ["type"], "properties": { "type": { "const": "approval_pending" } } },
      "then": {
        "required": ["toolUseId"],
        "properties": { "toolUseId": { "type": "string" } }
      }
    },
    {
      "if": { "required": ["type"], "properties": { "type": { "const": "approval_settled" } } },
      "then": {
        "required": ["toolUseId", "approved"],
        "properties": {
          "toolUseId": { "type": "string" },
          "approved": { "type": "boolean" }
        }
      }
    },
    {
      "if": { "required": ["type"], "properties": { "type": { "const": "usage" } } },
      "then": {
        "required": ["inputTokens", "cacheCreationTokens", "cacheReadTokens", "outputTokens", "costUsd"],
        "properties": {
          "inputTokens": { "type": "number" },
          "cacheCreationTokens": { "type": "number" },
          "cacheReadTokens": { "type": "number" },
          "outputTokens": { "type": "number" },
          "costUsd": { "type": "number" }
        }
      }
    }
  ]
}
