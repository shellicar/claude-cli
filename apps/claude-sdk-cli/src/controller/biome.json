{
  "root": false,
  "extends": "//",
  "linter": {
    "rules": {
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {},
            "patterns": [{ "group": ["../view/*"], "message": "controller/ must not import from view/" }, { "group": ["../app/*"], "message": "controller/ must not import from app/" }]
          }
        }
      }
    }
  }
}
