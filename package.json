{
  "name": "@shellicar/claude-cli",
  "version": "1.0.0-alpha.66",
  "private": false,
  "type": "module",
  "description": "Interactive CLI for Claude AI with terminal UI",
  "license": "MIT",
  "author": "Stephen Hellicar",
  "contributors": [
    "BananaBot9000 <bananabot9000@bananabot.dev>",
    "Claude (Anthropic) <noreply@anthropic.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shellicar/claude-cli.git"
  },
  "bugs": {
    "url": "https://github.com/shellicar/claude-cli/issues"
  },
  "homepage": "https://github.com/shellicar/claude-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "claude-cli": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node --inspect --import tsx src/main.ts",
    "build": "tsx build.ts",
    "build:watch": "tsx build.ts --watch",
    "start": "node dist/main.js",
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.check.json",
    "type-check:watch": "tsc -p tsconfig.check.json --watch --preserveWatchOutput",
    "ci": "biome check --diagnostic-level=error",
    "ci:fix": "biome check --diagnostic-level=error --write",
    "knip": "knip"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.77",
    "@js-joda/core": "^5.7.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@biomejs/biome": "^2.4.7",
    "@shellicar/build-clean": "^1.2.4",
    "@shellicar/build-version": "^1.3.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.4.0",
    "esbuild": "^0.27.3",
    "knip": "^5.86.0",
    "lefthook": "^2.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
